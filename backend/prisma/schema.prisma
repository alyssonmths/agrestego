// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Passageiro {
  id       Int       @id @default(autoincrement())
  nome     String
  email    String    @unique
  senha    String
  celular  String
  corridas Corrida[]
  imagemId Int? @unique
  imagem   Imagem?   @relation(fields: [imagemId], references: [id])
}

model Motorista {
  id       Int       @id @default(autoincrement())
  nome     String
  email    String    @unique
  senha    String
  celular  String
  cnh      String
  veiculo  String
  placa    String
  corridas Corrida[]
  imagemId Int? @unique
  imagem   Imagem?   @relation(fields: [imagemId], references: [id])
}

model Corrida {
  id           Int           @id @default(autoincrement())
  passageiroId Int
  motoristaId  Int?
  origemId     Int
  destinoId    Int
  origem       Bairro        @relation("CorridaOrigem", fields: [origemId], references: [id])
  destino      Bairro        @relation("CorridaDestino", fields: [destinoId], references: [id])
  status       StatusCorrida
  inicio       DateTime      @default(now())
  fim          DateTime?
  valor        Float
  passageiro   Passageiro    @relation(fields: [passageiroId], references: [id])
  motorista    Motorista?    @relation(fields: [motoristaId], references: [id])
  avaliacao    Avaliacao?
}

enum StatusCorrida {
  SOLICITADA
  CANCELADA
  INICIADA
  FINALIZADA
}

model Bairro {
  id              Int       @id @default(autoincrement())
  nome            String
  corridasOrigem  Corrida[] @relation("CorridaOrigem")
  corridasDestino Corrida[] @relation("CorridaDestino")
}

model Avaliacao {
  id             Int     @id @default(autoincrement())
  notaCorrida    Int?
  notaPassageiro Int?
  notaMotorista  Int?
  corridaId      Int     @unique
  corrida        Corrida @relation(fields: [corridaId], references: [id])
}

model Imagem {
  id          Int          @id @default(autoincrement())
  nome        String
  mimeType    String
  arquivo     Bytes
  passageiro Passageiro?
  motorista  Motorista?
}
